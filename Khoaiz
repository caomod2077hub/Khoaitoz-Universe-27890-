local function create(instanceType, parent, properties)
    local obj = Instance.new(instanceType)
    for k, v in pairs(properties) do obj[k] = v end
    obj.Parent = parent
    return obj
end

local function addCornerAndStroke(obj, radius, strokeThick)
    Instance.new("UICorner", obj).CornerRadius = UDim.new(0, radius)
    if strokeThick then local str = Instance.new("UIStroke", obj); str.Thickness = strokeThick; return str end
end

