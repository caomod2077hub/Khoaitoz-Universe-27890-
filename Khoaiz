local tInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local function nav(pOut, pIn, dir) TweenService:Create(pOut, tInfo, {Position = UDim2.new(dir, 0, 0.25, 0)}):Play(); TweenService:Create(pIn, tInfo, {Position = UDim2.new(0, 0, 0.25, 0)}):Play() end

