-- Feature Logic
SaveLocButton.MouseButton1Click:Connect(function() local hrp = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") if hrp then getgenv().KhoangLang_SavedPos = hrp.CFrame; SaveLocButton.Text = "Đã Lưu!"; task.wait(1.5); SaveLocButton.Text = "Save Location" end end)
TeleportButton.MouseButton1Click:Connect(function() local hrp = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") if getgenv().KhoangLang_SavedPos and hrp then hrp.CFrame = getgenv().KhoangLang_SavedPos; TeleportButton.Text = "Đã Tele!"; task.wait(1.5); TeleportButton.Text = "Teleport" end end)
SpinButton.MouseButton1Click:Connect(function() _G.Spinning = not _G.Spinning; SpinButton.Text = _G.Spinning and "Spinning..." or "Spin Me!" end)
RunService.RenderStepped:Connect(function() if _G.Spinning then local hrp = localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") if hrp then hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(15), 0) end end end)
ApplySpeedButton.MouseButton1Click:Connect(function() local n = tonumber(SpeedInput.Text) if n and localPlayer.Character:FindFirstChild("Humanoid") then localPlayer.Character.Humanoid.WalkSpeed = n; ApplySpeedButton.Text = "Done!"; task.wait(1.5); ApplySpeedButton.Text = "Apply Speed" end end)
ApplyJumpButton.MouseButton1Click:Connect(function() local n = tonumber(JumpInput.Text) local h = localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid") if n and h then h.UseJumpPower = true; h.JumpPower = n; ApplyJumpButton.Text = "Done!"; task.wait(1.5); ApplyJumpButton.Text = "Apply Jump" end end)
PlayMusicButton.MouseButton1Click:Connect(function() local id = MusicInput.Text:match("%d+") if id then ChillSound.SoundId = "rbxassetid://" .. id; if ChillSound.IsPlaying then ChillSound:Stop(); PlayMusicButton.Text = "▶️" else ChillSound:Play(); PlayMusicButton.Text = "⏸️" end end end)
LoadIYButton.MouseButton1Click:Connect(function() LoadIYButton.Text = "Loading..."; pcall(function() loadstring(game:HttpGet('https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source'))() end); LoadIYButton.Text = "Loaded ✔️" end)
